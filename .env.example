# Environment Variables for Marq AI Skills Platform
# Copy this to .env.local for local development

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=marq-ai-skills-platform-secret-key-2025

